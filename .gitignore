# Secrets / credentials — NEVER commit
.env
*.env.local
credentials.json
secrets/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# Data and models (too large / regeneratable)
data/raw/omie_pt_zips/
data/raw/entsoe/
data/raw/omie_es_zips/
*.pkl
logs/*.log

# OMIEForecast subfolder — exclude raw downloads and logs, keep processed
# outputs and trained models (≈10 MB total — needed by the dashboard).
omie_forecast/data/raw/
omie_forecast/logs/
# Allow the 48 OMIE model pkls (LASSO + LightGBM boosters) through the
# global "*.pkl" rule above.
!omie_forecast/models/
!omie_forecast/models/*.pkl
!omie_forecast/models/*.csv

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db
